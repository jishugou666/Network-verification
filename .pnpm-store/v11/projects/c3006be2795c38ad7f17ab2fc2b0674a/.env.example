# ==================== 数据库 ====================
# TiDB Serverless 连接串，强制 TLS
DATABASE_URL="mysql://user:password@gateway01.xxxxx.prod.aws.tidbcloud.com:4000/card_verify?sslaccept=strict"

# ==================== 应用 ====================
# 后端端口（Render 默认使用 PORT 环境变量）
PORT=3001
# 前端地址（CORS 白名单）
FRONTEND_URL="https://your-app.vercel.app"

# ==================== JWT ====================
# JWT 签名密钥（至少 32 字符随机字符串）
JWT_SECRET="change-me-to-a-random-64-char-string"
# JWT 过期时间
JWT_EXPIRES_IN="7d"

# ==================== AES 加密 ====================
# AES-256-GCM 加密密钥，用于加密存储 AppSecret
# 必须是 32 字节（64 字符 hex）的随机字符串
AES_ENCRYPTION_KEY="change-me-to-a-random-64-char-hex-string"

# ==================== 超级管理员 ====================
# 初始化超级管理员账号（首次启动时 seed 使用）
ROOT_USERNAME="admin"
ROOT_PASSWORD="change-me-to-a-strong-password"
ROOT_EMAIL="admin@example.com"

# ==================== 签名校验 ====================
# 时间戳最大允许偏差（秒），默认 30
SIGNATURE_TIMESTAMP_TOLERANCE=30
# Nonce 有效期（秒），默认 300（5分钟）
NONCE_TTL_SECONDS=300

# ==================== 限流 ====================
# 单 AppKey 每分钟最大请求数
RATE_LIMIT_PER_MINUTE=60

# 代理注册默认关闭；设置 true 才允许匿名注册代理账号
ALLOW_PUBLIC_AGENT_REGISTRATION=false

# ==================== 可选：Pusher Channels ====================
# PUSHER_APP_ID=""
# PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_CLUSTER="ap1"
